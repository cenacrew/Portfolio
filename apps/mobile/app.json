{
  "expo": {
    "name": "QRCodeAdmin",
    "slug": "qrcode-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "qrcodeadmin",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.cenacrew.qrcodeadmin",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0d0c62",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0d0c62",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "QRCodeAdmin utilise tes photos et vidéos pour les afficher sur le dashboard."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "QRCodeAdmin utilise ta position pour recentrer la carte « Ma loc » sur le dashboard."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0d0c62"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3a3f148b-a04e-488d-9700-a100e768d374"
      }
    },
    "owner": "cenacrew"
  }
}
