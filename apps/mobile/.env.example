# Supabase project credentials for the QRCodeAdmin mobile app.
# Copy to .env and fill in. These are PUBLIC (anon) values only.
# NEVER put the service_role key here: all writes go through the
# authenticated user session and are enforced by Supabase RLS.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
