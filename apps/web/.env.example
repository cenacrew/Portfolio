# ============================================================
# apps/web environment variables — copy to .env.local and fill in.
#
# IMPORTANT: with NONE of these set, the site still works: /qrcode falls back
# to the local config (apps/web/src/config/widgets.config.ts) and /adminqrcode
# redirects to a "not configured" login screen. Fill them in to enable the DB,
# admin editing, live guestbook/poll/visits and Spotify.
# ============================================================

# ---------- Supabase (required for DB + admin) ----------
# Supabase Dashboard > Project Settings > API (or "Data API" / "API Keys")

# "Project URL"  (e.g. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# "anon" / "public" key (a.k.a. "publishable key"). Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# "service_role" / "secret" key. SERVER-ONLY — never expose to the browser.
# Used by API routes for trusted writes (guestbook, poll) and photo uploads.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Poll anti-abuse (optional) ----------
# Salt for the per-visitor vote hash (IP + user-agent). Set any long random
# string. Defaults to a built-in value if unset.
POLL_HASH_SALT=

# ---------- Spotify "now playing" (optional) ----------
# Spotify Developer Dashboard (https://developer.spotify.com/dashboard):
# create an app -> Client ID + Client Secret. Then run the one-time OAuth
# authorization-code flow (scope: user-read-currently-playing) to obtain a
# refresh token. If any of the three is missing, the widget shows an idle state.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
